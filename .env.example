# Copy to .env

# SQLite — no database server required (file is created on first db push / seed)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string-at-least-32-chars"

# Public URL of the app (no trailing slash). On Railway, use your https://…up.railway.app or custom domain.
AUTH_URL="http://localhost:3000"

# Railway + SQLite volume (example — mount a volume at /data in the Railway service)
# DATABASE_URL="file:/data/synapse.db"

# Optional: Resend — real welcome + reminder emails (https://resend.com)
# RESEND_API_KEY=
# Must be a verified sender/domain in Resend; dev default may work for testing
# RESEND_FROM_EMAIL="Synapse <onboarding@resend.dev>"

# Synapse native video — Daily.co (free tier: https://www.daily.co/pricing)
# 1) https://www.daily.co/ → sign up / log in
# 2) https://dashboard.daily.co/developers → API keys → create & copy
# 3) Paste below and restart the dev server
# DAILY_API_KEY="your_key_here"
# When set, new events get a Daily room unless you paste broadcastEmbedUrl or set:
# SYNAPSE_VIDEO_AUTO_ROOM=false
#
# Cloud recording on new Daily rooms (MP4; Daily bills usage — see pricing). Host starts recording in Prebuilt UI.
# Set to false if you don't want recording enabled at the room level:
# SYNAPSE_DAILY_CLOUD_RECORDING=false
